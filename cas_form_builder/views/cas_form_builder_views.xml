<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_form_version_visual_builder" model="ir.ui.view">
        <field name="name">cas.form.version.form.visual.builder</field>
        <field name="model">cas.form.version</field>
        <field name="inherit_id" ref="cas_form_core.view_cas_form_version_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_publish']" position="before">
                <button name="action_open_visual_designer" type="object" string="طراح بصری" class="btn-secondary" groups="cas_form_core.group_cas_form_designer"/>
            </xpath>
            <xpath expr="//field[@name='schema_hash']" position="after">
                <field name="designer_revision" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
