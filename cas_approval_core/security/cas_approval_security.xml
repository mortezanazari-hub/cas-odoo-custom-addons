<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_cas_approval_user" model="res.groups">
        <field name="name">کاربر تأیید سازمانی</field>
        <field name="implied_ids" eval="[(4, ref('cas_workflow_core.group_cas_workflow_user'))]"/>
    </record>
    <record id="group_cas_approval_manager" model="res.groups">
        <field name="name">مدیر تأیید سازمانی</field>
        <field name="implied_ids" eval="[(4, ref('cas_approval_core.group_cas_approval_user')), (4, ref('cas_workflow_core.group_cas_workflow_manager'))]"/>
    </record>
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('cas_approval_core.group_cas_approval_manager'))]"/>
    </record>

    <record id="rule_approval_policy_company" model="ir.rule">
        <field name="name">سیاست تأیید: محدوده شرکت</field>
        <field name="model_id" ref="model_cas_approval_policy"/>
        <field name="groups" eval="[(4, ref('cas_approval_core.group_cas_approval_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_approval_step_company" model="ir.rule">
        <field name="name">گام تأیید: محدوده شرکت</field>
        <field name="model_id" ref="model_cas_approval_step"/>
        <field name="groups" eval="[(4, ref('cas_approval_core.group_cas_approval_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_approval_delegation_user" model="ir.rule">
        <field name="name">جانشینی تأیید: تفویض‌کننده یا جانشین</field>
        <field name="model_id" ref="model_cas_approval_delegation"/>
        <field name="groups" eval="[(4, ref('cas_approval_core.group_cas_approval_user'))]"/>
        <field name="domain_force">['&amp;', ('company_id', 'in', company_ids), '|', ('delegator_user_id', '=', user.id), ('delegate_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_approval_delegation_manager" model="ir.rule">
        <field name="name">جانشینی تأیید: مدیر شرکت</field>
        <field name="model_id" ref="model_cas_approval_delegation"/>
        <field name="groups" eval="[(4, ref('cas_approval_core.group_cas_approval_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_approval_request_user" model="ir.rule">
        <field name="name">درخواست تأیید: ذی‌نفع یا تأییدکننده</field>
        <field name="model_id" ref="model_cas_approval_request"/>
        <field name="groups" eval="[(4, ref('cas_approval_core.group_cas_approval_user'))]"/>
        <field name="domain_force">['&amp;', ('company_id', 'in', company_ids), '|', '|', '|', ('instance_id.started_by_id', '=', user.id), ('instance_id.responsible_user_id', '=', user.id), ('line_ids.approver_user_id', '=', user.id), ('line_ids.delegate_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_approval_request_manager" model="ir.rule">
        <field name="name">درخواست تأیید: مدیر شرکت</field>
        <field name="model_id" ref="model_cas_approval_request"/>
        <field name="groups" eval="[(4, ref('cas_approval_core.group_cas_approval_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_approval_line_user" model="ir.rule">
        <field name="name">خط تأیید: ذی‌نفع یا تأییدکننده</field>
        <field name="model_id" ref="model_cas_approval_line"/>
        <field name="groups" eval="[(4, ref('cas_approval_core.group_cas_approval_user'))]"/>
        <field name="domain_force">['&amp;', ('company_id', 'in', company_ids), '|', '|', '|', ('approver_user_id', '=', user.id), ('delegate_user_id', '=', user.id), ('instance_id.started_by_id', '=', user.id), ('instance_id.responsible_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_approval_line_manager" model="ir.rule">
        <field name="name">خط تأیید: مدیر شرکت</field>
        <field name="model_id" ref="model_cas_approval_line"/>
        <field name="groups" eval="[(4, ref('cas_approval_core.group_cas_approval_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_approval_history_user" model="ir.rule">
        <field name="name">تاریخچه تأیید: درخواست قابل مشاهده</field>
        <field name="model_id" ref="model_cas_approval_history"/>
        <field name="groups" eval="[(4, ref('cas_approval_core.group_cas_approval_user'))]"/>
        <field name="domain_force">['&amp;', ('company_id', 'in', company_ids), '|', '|', '|', ('request_id.instance_id.started_by_id', '=', user.id), ('request_id.instance_id.responsible_user_id', '=', user.id), ('request_id.line_ids.approver_user_id', '=', user.id), ('request_id.line_ids.delegate_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_approval_history_manager" model="ir.rule">
        <field name="name">تاریخچه تأیید: مدیر شرکت</field>
        <field name="model_id" ref="model_cas_approval_history"/>
        <field name="groups" eval="[(4, ref('cas_approval_core.group_cas_approval_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
