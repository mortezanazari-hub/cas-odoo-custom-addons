<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_document_backend_list" model="ir.ui.view">
        <field name="name">cas.document.storage.backend.list</field>
        <field name="model">cas.document.storage.backend</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="backend_type" widget="badge"/>
                <field name="base_url" optional="show"/>
                <field name="root_path" optional="show"/>
                <field name="is_default"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_document_backend_form" model="ir.ui.view">
        <field name="name">cas.document.storage.backend.form</field>
        <field name="model">cas.document.storage.backend</field>
        <field name="arch" type="xml">
            <form>
                <header><button name="action_test_connection" type="object" string="آزمون اتصال" class="btn-primary"/></header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group><field name="active"/><field name="sequence"/><field name="company_id"/><field name="backend_type"/><field name="is_default"/></group>
                        <group invisible="backend_type != 'nextcloud'">
                            <field name="base_url" placeholder="https://cloud.example.com"/>
                            <field name="root_path"/>
                            <field name="username"/>
                            <field name="secret_parameter_key"/>
                            <field name="timeout_seconds"/>
                            <field name="verify_ssl"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_document_backends" model="ir.actions.act_window">
        <field name="name">ذخیره‌سازها</field><field name="res_model">cas.document.storage.backend</field><field name="view_mode">list,form</field>
    </record>
</odoo>
