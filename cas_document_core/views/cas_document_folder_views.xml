<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_document_folder_list" model="ir.ui.view">
        <field name="name">cas.document.folder.list</field><field name="model">cas.document.folder</field>
        <field name="arch" type="xml">
            <list><field name="complete_name"/><field name="code"/><field name="manager_user_id"/><field name="confidentiality" widget="badge"/><field name="company_id" groups="base.group_multi_company"/><field name="active" widget="boolean_toggle"/></list>
        </field>
    </record>
    <record id="view_document_folder_form" model="ir.ui.view">
        <field name="name">cas.document.folder.form</field><field name="model">cas.document.folder</field>
        <field name="arch" type="xml">
            <form><sheet><div class="oe_title"><h1><field name="name"/></h1></div><group><group><field name="code"/><field name="company_id"/><field name="parent_id"/><field name="complete_name" readonly="1"/></group><group><field name="manager_user_id"/><field name="confidentiality"/><field name="active"/></group></group></sheet></form>
        </field>
    </record>
    <record id="action_document_folders" model="ir.actions.act_window">
        <field name="name">پوشه‌ها</field><field name="res_model">cas.document.folder</field><field name="view_mode">list,form</field>
    </record>
</odoo>
