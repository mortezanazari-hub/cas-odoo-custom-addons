<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_document_list" model="ir.ui.view">
        <field name="name">cas.document.list</field><field name="model">cas.document</field>
        <field name="arch" type="xml">
            <list create="1" edit="1" delete="0" decoration-muted="state in ('archived','destroyed')" decoration-danger="confidentiality == 'highly_confidential'">
                <field name="number"/><field name="name"/><field name="folder_id"/><field name="owner_user_id"/><field name="confidentiality" widget="badge"/><field name="version_count"/><field name="state" widget="badge"/><field name="retention_until"/><field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    <record id="view_document_search" model="ir.ui.view">
        <field name="name">cas.document.search</field><field name="model">cas.document</field>
        <field name="arch" type="xml"><search>
            <field name="number"/><field name="name"/><field name="folder_id"/><field name="owner_user_id"/><field name="tag_ids"/>
            <filter name="my_documents" string="اسناد من" domain="[('owner_user_id','=',uid)]"/>
            <filter name="active" string="فعال" domain="[('state','=','active')]"/>
            <filter name="confidential" string="محرمانه" domain="[('confidentiality','!=','normal')]"/>
            <filter name="legal_hold" string="توقف حقوقی" domain="[('legal_hold','=',True)]"/>
            <separator/><filter name="group_folder" string="پوشه" context="{'group_by':'folder_id'}"/><filter name="group_state" string="وضعیت" context="{'group_by':'state'}"/><filter name="group_owner" string="مالک" context="{'group_by':'owner_user_id'}"/>
        </search></field>
    </record>
    <record id="view_document_form" model="ir.ui.view">
        <field name="name">cas.document.form</field><field name="model">cas.document</field>
        <field name="arch" type="xml">
            <form create="1" edit="1" delete="0">
                <header>
                    <button name="action_open_upload_version" type="object" string="افزودن نسخه" class="btn-primary" invisible="state == 'destroyed'"/>
                    <button name="action_activate" type="object" string="فعال‌سازی" invisible="state != 'draft'"/>
                    <button name="action_archive" type="object" string="بایگانی" invisible="state not in ('draft','active')"/>
                    <button name="action_destroy" type="object" string="ثبت امحا" groups="cas_document_core.group_cas_document_manager" invisible="state == 'destroyed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,archived,destroyed"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" text="خیلی محرمانه" bg_color="text-bg-danger" invisible="confidentiality != 'highly_confidential'"/>
                    <div class="oe_title"><label for="number"/><h1><field name="number" readonly="1"/></h1><h2><field name="name"/></h2></div>
                    <group><group><field name="company_id"/><field name="folder_id"/><field name="owner_user_id"/><field name="authorized_user_ids" widget="many2many_tags"/></group><group><field name="confidentiality"/><field name="storage_backend_id"/><field name="tag_ids" widget="many2many_tags"/><field name="retention_until"/><field name="legal_hold"/></group></group>
                    <group><field name="description" nolabel="1" placeholder="شرح سند..."/></group>
                    <notebook>
                        <page string="نسخه‌ها"><field name="version_ids" readonly="1"><list create="0" edit="0" delete="0"><field name="version_number"/><field name="filename"/><field name="mimetype"/><field name="size_bytes"/><field name="sha256"/><field name="created_by_user_id"/><field name="created_at"/><button name="action_download" type="object" string="دریافت" icon="fa-download"/></list></field></page>
                        <page string="پیوندها"><field name="link_ids"><list editable="bottom"><field name="source_model"/><field name="source_record_id"/><field name="source_title"/><field name="relation_type"/></list></field></page>
                        <page string="تاریخچه رسمی"><field name="event_ids" readonly="1"><list create="0" edit="0" delete="0"><field name="event_at"/><field name="event_type" widget="badge"/><field name="actor_user_id"/><field name="version_id"/><field name="note"/></list></field></page>
                    </notebook>
                </sheet><chatter/>
            </form>
        </field>
    </record>
    <record id="action_documents" model="ir.actions.act_window">
        <field name="name">اسناد</field><field name="res_model">cas.document</field><field name="view_mode">list,form</field><field name="search_view_id" ref="view_document_search"/>
    </record>
</odoo>
