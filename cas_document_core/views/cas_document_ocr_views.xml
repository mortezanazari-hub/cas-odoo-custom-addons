<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_document_ocr_job_list" model="ir.ui.view"><field name="name">cas.document.ocr.job.list</field><field name="model">cas.document.ocr.job</field><field name="arch" type="xml"><list><field name="version_id"/><field name="provider_id"/><field name="state" widget="badge"/><field name="reviewer_user_id"/><field name="attempt_count"/><field name="completed_at"/><field name="company_id" groups="base.group_multi_company"/></list></field></record>
    <record id="view_document_ocr_job_form" model="ir.ui.view"><field name="name">cas.document.ocr.job.form</field><field name="model">cas.document.ocr.job</field><field name="arch" type="xml"><form><header><button name="action_submit_review" type="object" string="ارسال به بازبینی" invisible="state not in ('queued','failed')"/><button name="action_confirm_text" type="object" string="تأیید متن" class="btn-primary" invisible="state != 'review'"/><field name="state" widget="statusbar" statusbar_visible="queued,processing,review,done,failed"/></header><sheet><group><group><field name="version_id"/><field name="document_id"/><field name="provider_id"/><field name="reviewer_user_id"/></group><group><field name="attempt_count"/><field name="completed_at"/><field name="error_message"/></group></group><field name="extracted_text" placeholder="متن استخراج‌شده و بازبینی‌شده..."/></sheet><chatter/></form></field></record>
    <record id="action_document_ocr_jobs" model="ir.actions.act_window"><field name="name">صف OCR</field><field name="res_model">cas.document.ocr.job</field><field name="view_mode">list,form</field></record>
    <record id="view_document_ocr_provider_list" model="ir.ui.view"><field name="name">cas.document.ocr.provider.list</field><field name="model">cas.document.ocr.provider</field><field name="arch" type="xml"><list><field name="sequence" widget="handle"/><field name="name"/><field name="company_id"/><field name="provider_type" widget="badge"/><field name="endpoint_url"/><field name="active" widget="boolean_toggle"/></list></field></record>
    <record id="view_document_ocr_provider_form" model="ir.ui.view"><field name="name">cas.document.ocr.provider.form</field><field name="model">cas.document.ocr.provider</field><field name="arch" type="xml"><form><sheet><div class="oe_title"><h1><field name="name"/></h1></div><group><field name="active"/><field name="sequence"/><field name="company_id"/><field name="provider_type"/><field name="endpoint_url" invisible="provider_type != 'webhook'"/><field name="secret_parameter_key" invisible="provider_type != 'webhook'"/><field name="timeout_seconds"/></group></sheet></form></field></record>
    <record id="action_document_ocr_providers" model="ir.actions.act_window"><field name="name">سرویس‌های OCR</field><field name="res_model">cas.document.ocr.provider</field><field name="view_mode">list,form</field></record>
</odoo>
