<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_cas_document_user" model="res.groups">
        <field name="name">کاربر مدیریت اسناد</field>
    </record>
    <record id="group_cas_document_manager" model="res.groups">
        <field name="name">مدیر مدیریت اسناد</field>
        <field name="implied_ids" eval="[(4, ref('group_cas_document_user'))]"/>
    </record>
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('cas_document_core.group_cas_document_manager'))]"/>
    </record>

    <record id="rule_document_user_scope" model="ir.rule">
        <field name="name">سند: مالک، کاربر مجاز یا مدیر پوشه</field>
        <field name="model_id" ref="model_cas_document"/>
        <field name="groups" eval="[(4, ref('group_cas_document_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids), '|', '|', ('owner_user_id', '=', user.id), ('authorized_user_ids', 'in', user.id), ('folder_id.manager_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_document_manager_company" model="ir.rule">
        <field name="name">سند: مدیر در شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_document"/>
        <field name="groups" eval="[(4, ref('group_cas_document_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_document_folder_user" model="ir.rule">
        <field name="name">پوشه: عادی یا تحت مدیریت کاربر</field>
        <field name="model_id" ref="model_cas_document_folder"/>
        <field name="groups" eval="[(4, ref('group_cas_document_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids), '|', ('confidentiality', '=', 'normal'), ('manager_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_document_folder_manager" model="ir.rule">
        <field name="name">پوشه: مدیر در شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_document_folder"/>
        <field name="groups" eval="[(4, ref('group_cas_document_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_document_backend_company" model="ir.rule">
        <field name="name">ذخیره‌ساز: شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_document_storage_backend"/>
        <field name="groups" eval="[(4, ref('group_cas_document_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_document_version_scope" model="ir.rule">
        <field name="name">نسخه: سند قابل مشاهده</field>
        <field name="model_id" ref="model_cas_document_version"/>
        <field name="groups" eval="[(4, ref('group_cas_document_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids), '|', '|', ('document_id.owner_user_id', '=', user.id), ('document_id.authorized_user_ids', 'in', user.id), ('document_id.folder_id.manager_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_document_link_scope" model="ir.rule">
        <field name="name">پیوند: سند قابل مشاهده</field>
        <field name="model_id" ref="model_cas_document_link"/>
        <field name="groups" eval="[(4, ref('group_cas_document_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids), '|', '|', ('document_id.owner_user_id', '=', user.id), ('document_id.authorized_user_ids', 'in', user.id), ('document_id.folder_id.manager_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_document_event_scope" model="ir.rule">
        <field name="name">تاریخچه: سند قابل مشاهده</field>
        <field name="model_id" ref="model_cas_document_event"/>
        <field name="groups" eval="[(4, ref('group_cas_document_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids), '|', '|', ('document_id.owner_user_id', '=', user.id), ('document_id.authorized_user_ids', 'in', user.id), ('document_id.folder_id.manager_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_document_ocr_job_scope" model="ir.rule">
        <field name="name">OCR: سند قابل مشاهده</field>
        <field name="model_id" ref="model_cas_document_ocr_job"/>
        <field name="groups" eval="[(4, ref('group_cas_document_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids), '|', '|', ('document_id.owner_user_id', '=', user.id), ('document_id.authorized_user_ids', 'in', user.id), ('document_id.folder_id.manager_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_document_ocr_provider_company" model="ir.rule">
        <field name="name">سرویس OCR: شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_document_ocr_provider"/>
        <field name="groups" eval="[(4, ref('group_cas_document_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_document_version_manager" model="ir.rule">
        <field name="name">نسخه: مدیر در شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_document_version"/>
        <field name="groups" eval="[(4, ref('group_cas_document_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_document_link_manager" model="ir.rule">
        <field name="name">پیوند: مدیر در شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_document_link"/>
        <field name="groups" eval="[(4, ref('group_cas_document_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_document_event_manager" model="ir.rule">
        <field name="name">تاریخچه: مدیر در شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_document_event"/>
        <field name="groups" eval="[(4, ref('group_cas_document_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_document_ocr_job_manager" model="ir.rule">
        <field name="name">OCR: مدیر در شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_document_ocr_job"/>
        <field name="groups" eval="[(4, ref('group_cas_document_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
