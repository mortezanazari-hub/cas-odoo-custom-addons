<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_work_station_list" model="ir.ui.view">
        <field name="name">cas.work.station.list</field>
        <field name="model">cas.work.station</field>
        <field name="arch" type="xml">
            <list string="ایستگاه‌های کاری">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <field name="supervisor_user_id"/>
                <field name="normal_shift_hours"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_cas_work_station_form" model="ir.ui.view">
        <field name="name">cas.work.station.form</field>
        <field name="model">cas.work.station</field>
        <field name="arch" type="xml">
            <form string="ایستگاه کاری">
                <sheet>
                    <widget name="web_ribbon" title="غیرفعال" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="department_id" domain="[('company_id', 'in', [False, company_id])]"/>
                        </group>
                        <group>
                            <field name="supervisor_user_id"/>
                            <field name="normal_shift_hours"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_cas_work_station" model="ir.actions.act_window">
        <field name="name">ایستگاه‌های کاری</field>
        <field name="res_model">cas.work.station</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
