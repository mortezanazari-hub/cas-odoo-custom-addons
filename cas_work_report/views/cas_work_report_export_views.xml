<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_work_report_export_wizard_form" model="ir.ui.view">
        <field name="name">cas.work.report.export.wizard.form</field>
        <field name="model">cas.work.report.export.wizard</field>
        <field name="arch" type="xml">
            <form string="خروجی Excel گزارش‌های کار">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="state_code"/>
                    </group>
                    <group>
                        <field name="employee_id"/>
                        <field name="department_id"/>
                        <field name="work_station_id"/>
                    </group>
                </group>
                <footer>
                    <button name="action_export" type="object" string="دریافت Excel" class="btn-primary"/>
                    <button string="انصراف" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_cas_work_report_export" model="ir.actions.act_window">
        <field name="name">خروجی Excel</field>
        <field name="res_model">cas.work.report.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
