<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_work_report_search" model="ir.ui.view">
        <field name="name">cas.work.report.search</field>
        <field name="model">cas.work.report</field>
        <field name="arch" type="xml">
            <search string="جستجوی گزارش کار">
                <field name="number"/>
                <field name="employee_id"/>
                <field name="employee_department_id"/>
                <field name="work_station_id"/>
                <field name="supervisor_user_id"/>
                <filter name="my_reports" string="گزارش‌های من" domain="[('employee_id.user_id', '=', uid)]"/>
                <filter name="pending" string="در انتظار تأیید" domain="[('state', '=', 'pending')]"/>
                <filter name="late" string="ثبت با تأخیر" domain="[('is_late', '=', True)]"/>
                <separator/>
                <filter name="group_employee" string="کارمند" context="{'group_by': 'employee_id'}"/>
                <filter name="group_department" string="واحد" context="{'group_by': 'employee_department_id'}"/>
                <filter name="group_station" string="ایستگاه" context="{'group_by': 'work_station_id'}"/>
                <filter name="group_date" string="تاریخ کار" context="{'group_by': 'work_date'}"/>
                <filter name="group_state" string="وضعیت" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>
    <record id="view_cas_work_report_list" model="ir.ui.view">
        <field name="name">cas.work.report.list</field>
        <field name="model">cas.work.report</field>
        <field name="arch" type="xml">
            <list string="گزارش‌های کار" decoration-success="state_code == 'approved'" decoration-danger="state_code == 'rejected'" decoration-warning="state_code == 'pending'">
                <field name="number"/>
                <field name="work_date"/>
                <field name="employee_id"/>
                <field name="employee_department_id" optional="show"/>
                <field name="work_station_id"/>
                <field name="task_title"/>
                <field name="duration_hours" sum="جمع ساعات"/>
                <field name="overtime_hours" sum="جمع اضافه‌کاری" optional="show"/>
                <field name="supervisor_user_id" optional="show"/>
                <field name="state_code" column_invisible="True"/>
                <field name="state" widget="badge"/>
                <field name="is_late" optional="show"/>
            </list>
        </field>
    </record>
    <record id="view_cas_work_report_form" model="ir.ui.view">
        <field name="name">cas.work.report.form</field>
        <field name="model">cas.work.report</field>
        <field name="arch" type="xml">
            <form string="گزارش کار روزانه">
                <header>
                    <button name="action_submit" type="object" string="ارسال برای تأیید" class="btn-primary" invisible="state_code != 'draft'"/>
                    <field name="state" widget="badge"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="number"/>
                        <h1><field name="number" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="مشخصات کار">
                            <field name="work_date" readonly="state_code != 'draft'"/>
                            <field name="employee_id" readonly="state_code != 'draft'" domain="[('company_id', '=', company_id)]"/>
                            <field name="employee_department_id"/>
                            <field name="work_station_id" readonly="state_code != 'draft'" domain="[('company_id', '=', company_id)]"/>
                            <field name="station_department_id"/>
                        </group>
                        <group string="شیفت و تأیید">
                            <field name="shift_start" readonly="state_code != 'draft'"/>
                            <field name="shift_end" readonly="state_code != 'draft'"/>
                            <field name="duration_hours"/>
                            <field name="normal_hours"/>
                            <field name="overtime_hours"/>
                            <field name="supervisor_user_id" readonly="state_code != 'draft'"/>
                        </group>
                    </group>
                    <group>
                        <field name="task_title" readonly="state_code != 'draft'"/>
                    </group>
                    <notebook>
                        <page string="شرح و نتیجه">
                            <group>
                                <field name="description" readonly="state_code != 'draft'" placeholder="کار انجام‌شده را دقیق شرح دهید..."/>
                                <field name="result" readonly="state_code != 'draft'"/>
                                <field name="issues" readonly="state_code != 'draft'"/>
                            </group>
                        </page>
                        <page string="ثبت و پیگیری">
                            <group>
                                <field name="submitted_by_id"/>
                                <field name="is_representative_entry"/>
                                <field name="representation_delegation_id" invisible="not is_representative_entry"/>
                                <field name="submission_deadline"/>
                                <field name="submitted_at"/>
                                <field name="is_late"/>
                                <field name="late_reason" readonly="state_code != 'draft'"/>
                                <field name="workflow_instance_id"/>
                                <field name="approval_request_id"/>
                            </group>
                        </page>
                    </notebook>
                    <field name="company_id" invisible="1"/>
                    <field name="state_code" invisible="1"/>
                    <field name="authorized_user_ids" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_cas_work_report" model="ir.actions.act_window">
        <field name="name">گزارش‌های کار</field>
        <field name="res_model">cas.work.report</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cas_work_report_search"/>
    </record>
    <record id="action_cas_my_work_report" model="ir.actions.act_window">
        <field name="name">گزارش‌های من</field>
        <field name="res_model">cas.work.report</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('submitted_by_id', '=', uid)]</field>
        <field name="context">{'default_employee_id': False}</field>
    </record>
</odoo>
