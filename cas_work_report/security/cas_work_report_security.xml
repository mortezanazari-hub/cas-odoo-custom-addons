<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_cas_work_report_user" model="res.groups">
        <field name="name">کاربر گزارش کار</field>
        <field name="implied_ids" eval="[(4, ref('cas_workflow_core.group_cas_workflow_user')), (4, ref('cas_approval_core.group_cas_approval_user'))]"/>
    </record>
    <record id="group_cas_work_report_supervisor" model="res.groups">
        <field name="name">سرپرست گزارش کار</field>
        <field name="implied_ids" eval="[(4, ref('group_cas_work_report_user'))]"/>
    </record>
    <record id="group_cas_work_report_manager" model="res.groups">
        <field name="name">مدیر گزارش کار</field>
        <field name="implied_ids" eval="[(4, ref('group_cas_work_report_supervisor'))]"/>
    </record>
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('cas_work_report.group_cas_work_report_manager'))]"/>
    </record>

    <record id="rule_cas_work_station_company" model="ir.rule">
        <field name="name">ایستگاه‌های شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_work_station"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_cas_work_report_user'))]"/>
    </record>
    <record id="rule_cas_work_report_scope" model="ir.rule">
        <field name="name">گزارش‌های حوزه سازمانی مجاز</field>
        <field name="model_id" ref="model_cas_work_report"/>
        <field name="domain_force">[('company_id', 'in', company_ids), ('authorized_user_ids', 'in', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_cas_work_report_user'))]"/>
    </record>
    <record id="rule_cas_work_report_manager" model="ir.rule">
        <field name="name">مدیر گزارش کار در شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_work_report"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_cas_work_report_manager'))]"/>
    </record>
    <record id="rule_cas_work_report_delegation_user" model="ir.rule">
        <field name="name">مجوزهای نمایندگی کاربر</field>
        <field name="model_id" ref="model_cas_work_report_delegation"/>
        <field name="domain_force">[('company_id', 'in', company_ids), ('representative_user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_cas_work_report_user'))]"/>
    </record>
    <record id="rule_cas_work_report_delegation_manager" model="ir.rule">
        <field name="name">مدیریت مجوزهای نمایندگی شرکت</field>
        <field name="model_id" ref="model_cas_work_report_delegation"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_cas_work_report_manager'))]"/>
    </record>
</odoo>
