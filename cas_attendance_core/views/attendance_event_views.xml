<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_attendance_event_search" model="ir.ui.view"><field name="name">cas.attendance.event.search</field><field name="model">cas.attendance.event</field><field name="arch" type="xml"><search><field name="employee_id"/><field name="work_date"/><field name="source"/><field name="event_kind"/><filter name="active_events" string="رخدادهای معتبر" domain="[('is_void','=',False)]"/><filter name="void_events" string="باطل‌شده‌ها" domain="[('is_void','=',True)]"/><separator/><filter name="group_employee" string="کارمند" context="{'group_by':'employee_id'}"/><filter name="group_work_date" string="روز کاری" context="{'group_by':'work_date'}"/><filter name="group_source" string="منبع" context="{'group_by':'source'}"/></search></field></record>
    <record id="view_cas_attendance_event_list" model="ir.ui.view"><field name="name">cas.attendance.event.list</field><field name="model">cas.attendance.event</field><field name="arch" type="xml"><list delete="0"><field name="work_date"/><field name="occurred_at"/><field name="employee_id"/><field name="source"/><field name="event_kind"/><field name="site_id" optional="show"/><field name="device_id" optional="hide"/><field name="attribution_method" optional="show"/><field name="is_void"/></list></field></record>
    <record id="view_cas_attendance_event_form" model="ir.ui.view"><field name="name">cas.attendance.event.form</field><field name="model">cas.attendance.event</field><field name="arch" type="xml"><form delete="0"><header><button name="action_void" type="object" string="ابطال با حفظ سابقه" class="btn-secondary" groups="cas_attendance_core.group_cas_attendance_supervisor" invisible="is_void"/></header><sheet><div class="oe_title"><h1><field name="employee_id"/></h1></div><group><group><field name="occurred_at"/><field name="work_date"/><field name="attribution_method"/><field name="event_kind"/><field name="source"/></group><group><field name="site_id"/><field name="device_id"/><field name="registered_at"/><field name="external_uid"/><field name="is_void"/></group></group><field name="note"/><group string="ابطال و جایگزینی" invisible="not is_void and not void_reason"><field name="void_reason" readonly="is_void" required="is_void"/><field name="voided_at"/><field name="voided_by_id"/><field name="replacement_event_id"/></group></sheet><chatter/></form></field></record>
    <record id="action_cas_attendance_event" model="ir.actions.act_window"><field name="name">رخدادهای ورود و خروج</field><field name="res_model">cas.attendance.event</field><field name="view_mode">list,form</field><field name="context">{'search_default_active_events': 1}</field></record>
    <record id="action_cas_my_attendance_event" model="ir.actions.act_window"><field name="name">ورود و خروج‌های من</field><field name="res_model">cas.attendance.event</field><field name="view_mode">list,form</field><field name="domain">[('employee_id.user_id','=',uid)]</field><field name="context">{'create': False, 'edit': False, 'delete': False, 'search_default_active_events': 1}</field></record>
</odoo>
