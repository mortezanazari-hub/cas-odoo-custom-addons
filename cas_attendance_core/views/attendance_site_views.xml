<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_attendance_site_list" model="ir.ui.view"><field name="name">cas.attendance.site.list</field><field name="model">cas.attendance.site</field><field name="arch" type="xml"><list><field name="name"/><field name="code"/><field name="company_id" groups="base.group_multi_company"/><field name="active"/></list></field></record>
    <record id="view_cas_attendance_site_form" model="ir.ui.view"><field name="name">cas.attendance.site.form</field><field name="model">cas.attendance.site</field><field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="code"/><field name="company_id" groups="base.group_multi_company"/><field name="active"/></group></sheet><chatter/></form></field></record>
    <record id="action_cas_attendance_site" model="ir.actions.act_window"><field name="name">ساختمان‌ها و محل‌ها</field><field name="res_model">cas.attendance.site</field><field name="view_mode">list,form</field></record>
    <record id="view_cas_attendance_device_list" model="ir.ui.view"><field name="name">cas.attendance.device.list</field><field name="model">cas.attendance.device</field><field name="arch" type="xml"><list><field name="name"/><field name="code"/><field name="site_id"/><field name="active"/></list></field></record>
    <record id="view_cas_attendance_device_form" model="ir.ui.view"><field name="name">cas.attendance.device.form</field><field name="model">cas.attendance.device</field><field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="code"/><field name="site_id"/><field name="company_id" groups="base.group_multi_company"/><field name="active"/></group><field name="note"/></sheet><chatter/></form></field></record>
    <record id="action_cas_attendance_device" model="ir.actions.act_window"><field name="name">دستگاه‌های حضور</field><field name="res_model">cas.attendance.device</field><field name="view_mode">list,form</field></record>
    <record id="view_cas_attendance_outage_list" model="ir.ui.view"><field name="name">cas.attendance.outage.list</field><field name="model">cas.attendance.outage</field><field name="arch" type="xml"><list><field name="name"/><field name="site_id"/><field name="device_id"/><field name="start_at"/><field name="end_at"/><field name="state"/></list></field></record>
    <record id="view_cas_attendance_outage_form" model="ir.ui.view"><field name="name">cas.attendance.outage.form</field><field name="model">cas.attendance.outage</field><field name="arch" type="xml"><form><header><button name="action_recover" type="object" string="ثبت رفع خرابی" class="btn-primary" invisible="state != 'open'"/><field name="state" widget="statusbar"/></header><sheet><group><group><field name="name"/><field name="site_id"/><field name="device_id"/></group><group><field name="start_at"/><field name="end_at" readonly="state == 'recovered'"/><field name="reporter_id"/></group></group><field name="reason"/></sheet><chatter/></form></field></record>
    <record id="action_cas_attendance_outage" model="ir.actions.act_window"><field name="name">خرابی دستگاه</field><field name="res_model">cas.attendance.outage</field><field name="view_mode">list,form</field></record>
</odoo>
