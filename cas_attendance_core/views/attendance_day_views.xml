<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_attendance_day_search" model="ir.ui.view"><field name="name">cas.attendance.day.search</field><field name="model">cas.attendance.day</field><field name="arch" type="xml"><search><field name="employee_id"/><field name="work_date"/><field name="state"/><filter name="needs_review" string="نیازمند رسیدگی" domain="[('state','in',('conflict','incomplete','warning'))]"/><filter name="conflicts" string="اختلاف منابع" domain="[('state','=','conflict')]"/><separator/><filter name="group_employee" string="کارمند" context="{'group_by':'employee_id'}"/><filter name="group_state" string="وضعیت" context="{'group_by':'state'}"/><filter name="group_date" string="روز کاری" context="{'group_by':'work_date'}"/></search></field></record>
    <record id="view_cas_attendance_day_list" model="ir.ui.view"><field name="name">cas.attendance.day.list</field><field name="model">cas.attendance.day</field><field name="arch" type="xml"><list create="0" delete="0"><field name="work_date"/><field name="employee_id"/><field name="attendance_mode"/><field name="effective_entry"/><field name="effective_exit"/><field name="state" decoration-danger="state == 'conflict'" decoration-warning="state in ('warning','incomplete')"/><field name="warning_code" optional="show"/></list></field></record>
    <record id="view_cas_attendance_day_form" model="ir.ui.view"><field name="name">cas.attendance.day.form</field><field name="model">cas.attendance.day</field><field name="arch" type="xml"><form create="0" delete="0"><header><button name="recompute" type="object" string="محاسبه مجدد" groups="cas_attendance_core.group_cas_attendance_supervisor" invisible="state == 'resolved'"/><button name="action_resolve" type="object" string="ثبت تصمیم سرپرست" class="btn-primary" groups="cas_attendance_core.group_cas_attendance_supervisor" invisible="state != 'conflict'"/><field name="state" widget="statusbar"/></header><sheet><group><group><field name="employee_id" readonly="1"/><field name="work_date" readonly="1"/><field name="shift_day_id" readonly="1"/><field name="attendance_mode" readonly="1"/></group><group><field name="effective_entry" readonly="1"/><field name="effective_exit" readonly="1"/><field name="tolerance_minutes" readonly="1"/><field name="warning_code" readonly="1"/></group></group><group string="مقایسه نگهبانی و دستگاه" invisible="attendance_mode != 'simple'"><group><field name="guard_entry"/><field name="guard_exit"/></group><group><field name="device_entry"/><field name="device_exit"/></group></group><group string="تصمیم سرپرست" invisible="state not in ('conflict','resolved')"><group><field name="resolution_entry_source" readonly="state == 'resolved'"/><field name="custom_entry" invisible="resolution_entry_source != 'custom'" readonly="state == 'resolved'"/><field name="resolution_exit_source" readonly="state == 'resolved'"/><field name="custom_exit" invisible="resolution_exit_source != 'custom'" readonly="state == 'resolved'"/></group><group><field name="resolution_reason" readonly="state == 'resolved'"/><field name="resolved_by_id"/><field name="resolved_at"/></group></group><notebook><page string="رخدادهای خام"><field name="event_ids" readonly="1"><list create="0" delete="0"><field name="occurred_at"/><field name="source"/><field name="event_kind"/><field name="site_id" optional="show"/><field name="is_void"/></list></field></page><page string="بازه‌های پیشرفته" invisible="attendance_mode != 'advanced'"><field name="interval_ids" readonly="1"><list create="0" delete="0"><field name="interval_type"/><field name="start_at"/><field name="end_at"/><field name="duration_minutes"/></list></field></page></notebook></sheet><chatter/></form></field></record>
    <record id="action_cas_attendance_day" model="ir.actions.act_window"><field name="name">روزهای حضور</field><field name="res_model">cas.attendance.day</field><field name="view_mode">list,form</field></record>
    <record id="action_cas_my_attendance_day" model="ir.actions.act_window"><field name="name">حضور من</field><field name="res_model">cas.attendance.day</field><field name="view_mode">list,form</field><field name="domain">[('employee_id.user_id','=',uid)]</field><field name="context">{'create': False, 'edit': False, 'delete': False}</field></record>
</odoo>
