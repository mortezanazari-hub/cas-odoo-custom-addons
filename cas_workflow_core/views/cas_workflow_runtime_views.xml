<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_workflow_instance_list" model="ir.ui.view">
        <field name="name">cas.workflow.instance.list</field>
        <field name="model">cas.workflow.instance</field>
        <field name="arch" type="xml">
            <list string="کارتابل گردش‌کار" create="0" delete="0">
                <field name="number"/>
                <field name="definition_id"/>
                <field name="resource_display_name"/>
                <field name="current_state_id"/>
                <field name="responsible_user_id"/>
                <field name="state_deadline"/>
                <field name="status"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_cas_workflow_instance_form" model="ir.ui.view">
        <field name="name">cas.workflow.instance.form</field>
        <field name="model">cas.workflow.instance</field>
        <field name="arch" type="xml">
            <form string="نمونه گردش‌کار" create="0" delete="0" edit="0">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="running,completed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="number"/></h1></div>
                    <group>
                        <group>
                            <field name="definition_id"/>
                            <field name="version_id"/>
                            <field name="current_state_id"/>
                            <field name="responsible_user_id"/>
                        </group>
                        <group>
                            <field name="resource_model"/>
                            <field name="resource_id"/>
                            <field name="resource_display_name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <field name="started_by_id"/>
                        <field name="started_at"/>
                        <field name="state_entered_at"/>
                        <field name="state_deadline"/>
                        <field name="completed_at"/>
                    </group>
                    <notebook>
                        <page string="تاریخچه">
                            <field name="history_ids" readonly="1">
                                <list create="0" delete="0">
                                    <field name="event_at"/>
                                    <field name="event_type"/>
                                    <field name="from_state_id"/>
                                    <field name="to_state_id"/>
                                    <field name="transition_id"/>
                                    <field name="actor_user_id"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_cas_workflow_instance_search" model="ir.ui.view">
        <field name="name">cas.workflow.instance.search</field>
        <field name="model">cas.workflow.instance</field>
        <field name="arch" type="xml">
            <search string="جست‌وجوی گردش‌کار">
                <field name="number"/>
                <field name="definition_id"/>
                <field name="resource_display_name"/>
                <field name="responsible_user_id"/>
                <field name="current_state_id"/>
                <filter name="running" string="در جریان" domain="[('status', '=', 'running')]"/>
                <filter name="my_responsibility" string="مسئولیت من" domain="[('responsible_user_id', '=', uid)]"/>
                <filter name="group_definition" string="گروه‌بندی بر اساس گردش‌کار" context="{'group_by': 'definition_id'}"/>
                <filter name="group_state" string="گروه‌بندی بر اساس وضعیت" context="{'group_by': 'current_state_id'}"/>
                <filter name="group_responsible" string="گروه‌بندی بر اساس مسئول" context="{'group_by': 'responsible_user_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_cas_workflow_instance" model="ir.actions.act_window">
        <field name="name">کارتابل گردش‌کار</field>
        <field name="res_model">cas.workflow.instance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cas_workflow_instance_search"/>
        <field name="context">{'search_default_running': 1}</field>
    </record>
</odoo>
