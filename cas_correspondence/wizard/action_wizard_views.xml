<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_correspondence_complete_wizard_form" model="ir.ui.view">
        <field name="name">cas.correspondence.complete.wizard.form</field>
        <field name="model">cas.correspondence.complete.wizard</field>
        <field name="arch" type="xml">
            <form string="ثبت نتیجه اقدام">
                <field name="source_model" invisible="1"/>
                <field name="source_id" invisible="1"/>
                <field name="result" placeholder="نتیجه انجام کار را دقیق ثبت کنید..."/>
                <footer>
                    <button name="action_confirm" type="object" string="ثبت نتیجه" class="btn-primary"/>
                    <button string="انصراف" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="view_correspondence_delegation_revoke_wizard_form" model="ir.ui.view">
        <field name="name">cas.correspondence.delegation.revoke.wizard.form</field>
        <field name="model">cas.correspondence.delegation.revoke.wizard</field>
        <field name="arch" type="xml">
            <form string="لغو تفویض دبیرخانه">
                <field name="delegation_id"/>
                <field name="reason" placeholder="دلیل لغو تفویض..."/>
                <footer>
                    <button name="action_confirm" type="object" string="لغو تفویض" class="btn-danger"/>
                    <button string="انصراف" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
