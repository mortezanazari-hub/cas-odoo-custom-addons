<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_correspondence_referral_wizard_form" model="ir.ui.view">
        <field name="name">cas.correspondence.referral.wizard.form</field>
        <field name="model">cas.correspondence.referral.wizard</field>
        <field name="arch" type="xml">
            <form string="ارجاع نامه">
                <group>
                    <field name="letter_id"/>
                    <field name="target_kind"/>
                    <field name="recipient_user_id" invisible="target_kind != 'user'" required="target_kind == 'user'"/>
                    <field name="department_id" invisible="target_kind != 'department'" required="target_kind == 'department'"/>
                    <field name="expectation"/>
                    <field name="priority"/>
                    <field name="deadline"/>
                    <field name="note"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="ثبت ارجاع" class="btn-primary"/>
                    <button string="انصراف" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
