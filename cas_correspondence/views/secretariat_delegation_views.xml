<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_secretariat_delegation_list" model="ir.ui.view">
        <field name="name">cas.correspondence.secretariat.delegation.list</field>
        <field name="model">cas.correspondence.secretariat.delegation</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="delegate_user_id"/>
                <field name="delegator_user_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="active"/>
                <field name="revoked_at"/>
            </list>
        </field>
    </record>
    <record id="view_secretariat_delegation_form" model="ir.ui.view">
        <field name="name">cas.correspondence.secretariat.delegation.form</field>
        <field name="model">cas.correspondence.secretariat.delegation</field>
        <field name="arch" type="xml">
            <form string="تفویض دبیرخانه">
                <header>
                    <button name="action_open_revoke_wizard" type="object" string="لغو تفویض" class="btn-secondary" invisible="not active"/>
                    <field name="active" widget="boolean_toggle" readonly="1"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id" readonly="not active"/>
                            <field name="delegator_user_id" readonly="1"/>
                            <field name="delegate_user_id" readonly="not active"/>
                        </group>
                        <group>
                            <field name="date_from" readonly="not active"/>
                            <field name="date_to" readonly="not active"/>
                            <field name="revoked_at" readonly="1" invisible="not revoked_at"/>
                            <field name="revoked_by_id" readonly="1" invisible="not revoked_by_id"/>
                        </group>
                    </group>
                    <field name="reason" readonly="not active"/>
                    <field name="revocation_reason" readonly="1" invisible="not revocation_reason"/>
                    <notebook>
                        <page string="تاریخچه رسمی">
                            <field name="audit_ids" readonly="1">
                                <list create="0" delete="0">
                                    <field name="event_at"/>
                                    <field name="event_type"/>
                                    <field name="actor_user_id"/>
                                    <field name="reason"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_secretariat_delegations" model="ir.actions.act_window">
        <field name="name">تفویض‌های دبیرخانه</field>
        <field name="res_model">cas.correspondence.secretariat.delegation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
