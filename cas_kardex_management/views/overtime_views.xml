<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_overtime_request_search" model="ir.ui.view"><field name="name">cas.overtime.request.search</field><field name="model">cas.overtime.request</field><field name="arch" type="xml"><search><field name="number"/><field name="employee_id"/><field name="work_date"/><field name="state"/><filter name="pending" string="در انتظار رسیدگی" domain="[('state','in',('pending_manager','pending_ceo'))]"/><filter name="manager_pending" string="در انتظار مدیر" domain="[('state','=','pending_manager')]"/><filter name="ceo_pending" string="در انتظار مدیرعامل" domain="[('state','=','pending_ceo')]"/><separator/><filter name="group_employee" string="کارمند" context="{'group_by':'employee_id'}"/><filter name="group_state" string="وضعیت" context="{'group_by':'state'}"/></search></field></record>
    <record id="view_cas_overtime_request_list" model="ir.ui.view"><field name="name">cas.overtime.request.list</field><field name="model">cas.overtime.request</field><field name="arch" type="xml"><list delete="0"><field name="number"/><field name="work_date"/><field name="employee_id"/><field name="actual_minutes"/><field name="manager_approved_minutes"/><field name="ceo_approved_minutes"/><field name="final_approved_minutes"/><field name="state"/></list></field></record>
    <record id="view_cas_overtime_request_form" model="ir.ui.view"><field name="name">cas.overtime.request.form</field><field name="model">cas.overtime.request</field><field name="arch" type="xml"><form delete="0"><header><button name="action_submit" type="object" string="ارسال برای تأیید" class="btn-primary" invisible="state != 'draft'"/><button name="action_manager_approve" type="object" string="ارسال مقدار تأییدشده به مدیرعامل" class="btn-primary" invisible="state != 'pending_manager'" groups="cas_kardex_management.group_cas_kardex_supervisor"/><button name="action_ceo_finalize" type="object" string="ثبت تصمیم نهایی مدیرعامل" class="btn-primary" invisible="state != 'pending_ceo'" groups="cas_kardex_management.group_cas_kardex_ceo"/><field name="state" widget="statusbar"/></header><sheet><div class="oe_title"><h1><field name="number"/></h1></div><group><group><field name="employee_id"/><field name="kardex_day_id" readonly="state != 'draft'"/><field name="work_date"/><field name="actual_minutes"/></group><group><field name="manager_user_id"/><field name="authorization_id"/><field name="submitted_at"/><field name="finalized_at"/></group></group><field name="reason" readonly="state != 'draft'"/><group string="تصمیم مدیر"><field name="manager_approved_minutes" readonly="state != 'pending_manager'"/><field name="manager_note" readonly="state != 'pending_manager'"/></group><group string="تصمیم مدیرعامل"><field name="ceo_approved_minutes" readonly="state != 'pending_ceo'"/><field name="ceo_note" readonly="state != 'pending_ceo'"/><field name="final_approved_minutes"/></group></sheet><chatter/></form></field></record>
    <record id="action_cas_overtime_request" model="ir.actions.act_window"><field name="name">اضافه‌کاری‌های انجام‌شده</field><field name="res_model">cas.overtime.request</field><field name="view_mode">list,form</field><field name="context">{'search_default_pending':1}</field></record>

    <record id="view_cas_overtime_authorization_list" model="ir.ui.view"><field name="name">cas.overtime.authorization.list</field><field name="model">cas.overtime.authorization</field><field name="arch" type="xml"><list create="1" delete="0"><field name="employee_id"/><field name="grant_scope"/><field name="effective_from"/><field name="date_to"/><field name="active"/><field name="granted_by_id"/></list></field></record>
    <record id="view_cas_overtime_authorization_form" model="ir.ui.view"><field name="name">cas.overtime.authorization.form</field><field name="model">cas.overtime.authorization</field><field name="arch" type="xml"><form delete="0"><header><button name="action_revoke" type="object" string="لغو با حفظ سابقه" invisible="not active" class="btn-secondary" groups="cas_kardex_management.group_cas_kardex_ceo"/></header><sheet><group><group><field name="employee_id" readonly="granted_at"/><field name="grant_scope" readonly="granted_at"/><field name="effective_from"/><field name="date_to" readonly="not active"/><field name="review_rejected_cases" readonly="not active"/></group><group><field name="active"/><field name="granted_by_id"/><field name="granted_at"/><field name="revoked_by_id"/><field name="revoked_at"/></group></group><field name="reason" readonly="granted_at"/><field name="revoke_reason" readonly="not active"/></sheet><chatter/></form></field></record>
    <record id="action_cas_overtime_authorization" model="ir.actions.act_window"><field name="name">مجوز خودکار اضافه‌کاری</field><field name="res_model">cas.overtime.authorization</field><field name="view_mode">list,form</field></record>
</odoo>

