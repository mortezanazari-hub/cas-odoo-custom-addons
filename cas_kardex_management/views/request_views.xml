<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_attendance_request_search" model="ir.ui.view"><field name="name">cas.attendance.request.search</field><field name="model">cas.attendance.request</field><field name="arch" type="xml"><search><field name="number"/><field name="employee_id"/><field name="request_type"/><field name="date_from"/><filter name="pending" string="در انتظار رسیدگی" domain="[('state','=','pending')]"/><separator/><filter name="group_employee" string="کارمند" context="{'group_by':'employee_id'}"/><filter name="group_state" string="وضعیت" context="{'group_by':'state'}"/></search></field></record>
    <record id="view_cas_attendance_request_list" model="ir.ui.view"><field name="name">cas.attendance.request.list</field><field name="model">cas.attendance.request</field><field name="arch" type="xml"><list delete="0"><field name="number"/><field name="employee_id"/><field name="request_type"/><field name="duration_type"/><field name="date_from"/><field name="date_to"/><field name="requested_minutes"/><field name="approver_user_id"/><field name="state"/></list></field></record>
    <record id="view_cas_attendance_request_form" model="ir.ui.view"><field name="name">cas.attendance.request.form</field><field name="model">cas.attendance.request</field><field name="arch" type="xml"><form delete="0"><header><button name="action_submit" type="object" string="ارسال درخواست" class="btn-primary" invisible="state != 'draft'"/><button name="action_approve" type="object" string="تأیید" class="btn-primary" invisible="state != 'pending'" groups="cas_kardex_management.group_cas_kardex_supervisor"/><button name="action_reject" type="object" string="رد با توضیح" invisible="state != 'pending'" groups="cas_kardex_management.group_cas_kardex_supervisor"/><button name="action_cancel" type="object" string="لغو" invisible="state not in ('draft','pending')"/><field name="state" widget="statusbar"/></header><sheet><div class="oe_title"><h1><field name="number"/></h1></div><group><group><field name="employee_id" readonly="state != 'draft'"/><field name="request_type" readonly="state != 'draft'"/><field name="duration_type" readonly="state != 'draft'"/><field name="source_attendance_day_id" readonly="1"/></group><group><field name="date_from" readonly="state != 'draft'"/><field name="date_to" readonly="state != 'draft'"/><field name="datetime_from" invisible="duration_type != 'hourly'" required="duration_type == 'hourly'" readonly="state != 'draft'"/><field name="datetime_to" invisible="duration_type != 'hourly'" required="duration_type == 'hourly'" readonly="state != 'draft'"/><field name="requested_minutes"/></group></group><field name="reason" readonly="state != 'draft'"/><group string="رسیدگی"><field name="approver_user_id"/><field name="approver_role"/><field name="decision_note" readonly="state not in ('pending','rejected')"/><field name="decision_user_id"/><field name="decided_at"/></group></sheet><chatter/></form></field></record>
    <record id="action_cas_my_attendance_request" model="ir.actions.act_window"><field name="name">درخواست‌های من</field><field name="res_model">cas.attendance.request</field><field name="view_mode">list,form</field><field name="domain">[('employee_id.user_id','=',uid)]</field></record>
    <record id="action_cas_attendance_request_review" model="ir.actions.act_window"><field name="name">مرخصی و مأموریت</field><field name="res_model">cas.attendance.request</field><field name="view_mode">list,form</field><field name="context">{'search_default_pending':1}</field></record>
    <record id="view_cas_attendance_day_kardex_inherit" model="ir.ui.view"><field name="name">cas.attendance.day.form.kardex.request</field><field name="model">cas.attendance.day</field><field name="inherit_id" ref="cas_attendance_core.view_cas_attendance_day_form"/><field name="arch" type="xml"><xpath expr="//header" position="inside"><button name="action_new_attendance_request" type="object" string="درخواست مرخصی / مأموریت" groups="cas_kardex_management.group_cas_kardex_user"/></xpath></field></record>
</odoo>
