    <record id="view_cas_kardex_day_form" model="ir.ui.view"><field name="name">cas.kardex.day.form</field><field name="model">cas.kardex.day</field><field name="arch" type="xml"><form create="0" delete="0"><header><button name="recompute" type="object" string="محاسبه مجدد" groups="cas_kardex_management.group_cas_kardex_supervisor"/><button name="action_approve_break_waiver" type="object" string="تأیید عدم استفاده از استراحت" class="btn-primary" invisible="break_waiver_state != 'pending'" groups="cas_kardex_management.group_cas_kardex_supervisor"/><button name="action_reject_break_waiver" type="object" string="ثبت نیم‌ساعت کسری" invisible="break_waiver_state != 'pending'" groups="cas_kardex_management.group_cas_kardex_supervisor"/><field name="state" widget="statusbar"/></header><sheet><group><group><field name="employee_id"/><field name="work_date"/><field name="attendance_day_id"/><field name="shift_day_id"/><field name="period_id"/><field name="day_kind"/></group><group><field name="planned_base_minutes"/><field name="planned_presence_minutes"/><field name="planned_break_minutes"/><field name="presence_minutes"/><field name="deducted_break_minutes"/><field name="net_work_minutes"/></group></group><group string="پوشش موظفی"><field name="leave_minutes"/><field name="mission_minutes"/><field name="credited_base_minutes"/><field name="absence_minutes"/><field name="tardy_minutes"/><field name="early_exit_minutes"/></group><group string="اضافه‌کاری" groups="cas_kardex_management.group_cas_kardex_supervisor"><field name="mandatory_overtime_minutes"/><field name="discretionary_overtime_minutes"/><field name="approved_overtime_minutes"/><field name="holiday_work_minutes"/></group><group string="تصمیم استراحت"><field name="break_waiver_state"/><field name="break_waiver_reason" readonly="break_waiver_state != 'pending'"/><field name="break_waiver_by_id"/><field name="break_waiver_at"/></group></sheet><chatter/></form></field></record>
    <record id="view_cas_my_kardex_day_list" model="ir.ui.view"><field name="name">cas.kardex.day.my.list</field><field name="model">cas.kardex.day</field><field name="priority">5</field><field name="arch" type="xml"><list create="0" edit="0" delete="0"><field name="work_date"/><field name="day_kind"/><field name="presence_minutes"/><field name="net_work_minutes"/><field name="leave_minutes"/><field name="mission_minutes"/><field name="absence_minutes"/><field name="tardy_minutes"/><field name="early_exit_minutes"/><field name="state"/></list></field></record>
    <record id="action_cas_kardex_day" model="ir.actions.act_window"><field name="name">کاردکس روزانه</field><field name="res_model">cas.kardex.day</field><field name="view_mode">list,form</field></record>
    <record id="action_cas_my_kardex_day" model="ir.actions.act_window"><field name="name">کاردکس من</field><field name="res_model">cas.kardex.day</field><field name="view_mode">list</field><field name="view_id" ref="view_cas_my_kardex_day_list"/><field name="domain">[('employee_id.user_id','=',uid)]</field></record>

    <record id="view_cas_kardex_period_list" model="ir.ui.view"><field name="name">cas.kardex.period.list</field><field name="model">cas.kardex.period</field><field name="arch" type="xml"><list delete="0"><field name="month_start"/><field name="month_end"/><field name="company_id" groups="base.group_multi_company"/><field name="lock_deadline"/><field name="state"/><field name="locked_at"/></list></field></record>
    <record id="view_cas_kardex_period_form" model="ir.ui.view"><field name="name">cas.kardex.period.form</field><field name="model">cas.kardex.period</field><field name="arch" type="xml"><form delete="0"><header><button name="action_lock" type="object" string="قفل دوره" class="btn-primary" invisible="state != 'open'" groups="cas_kardex_management.group_cas_kardex_manager"/><field name="state" widget="statusbar"/></header><sheet><group><field name="company_id" groups="base.group_multi_company"/><field name="month_start" readonly="state != 'open'"/><field name="month_end"/><field name="lock_deadline"/><field name="locked_at"/><field name="locked_by_id"/></group><field name="reopen_ids" readonly="1"><list create="0" delete="0"><field name="date_from"/><field name="date_to"/><field name="scope"/><field name="active"/><field name="opened_by_id"/></list></field></sheet><chatter/></form></field></record>
    <record id="action_cas_kardex_period" model="ir.actions.act_window"><field name="name">دوره‌ها و قفل ماه</field><field name="res_model">cas.kardex.period</field><field name="view_mode">list,form</field></record>

    <record id="view_cas_kardex_reopen_list" model="ir.ui.view"><field name="name">cas.kardex.reopen.list</field><field name="model">cas.kardex.reopen</field><field name="arch" type="xml"><list delete="0"><field name="period_id"/><field name="date_from"/><field name="date_to"/><field name="scope"/><field name="employee_ids" widget="many2many_tags"/><field name="active"/><field name="opened_by_id"/></list></field></record>
    <record id="view_cas_kardex_reopen_form" model="ir.ui.view"><field name="name">cas.kardex.reopen.form</field><field name="model">cas.kardex.reopen</field><field name="arch" type="xml"><form delete="0"><header><button name="action_close" type="object" string="بستن بازگشایی" invisible="not active" groups="cas_kardex_management.group_cas_kardex_ceo"/></header><sheet><group><group><field name="period_id" readonly="opened_at"/><field name="date_from" readonly="opened_at"/><field name="date_to" readonly="opened_at"/><field name="scope" readonly="opened_at"/><field name="employee_ids" widget="many2many_tags" invisible="scope != 'employees'" required="scope == 'employees'" readonly="opened_at"/></group><group><field name="active"/><field name="opened_by_id"/><field name="opened_at"/><field name="closed_by_id"/><field name="closed_at"/></group></group><field name="reason" readonly="opened_at"/></sheet><chatter/></form></field></record>
    <record id="action_cas_kardex_reopen" model="ir.actions.act_window"><field name="name">بازگشایی کاردکس</field><field name="res_model">cas.kardex.reopen</field><field name="view_mode">list,form</field></record>
</odoo>

