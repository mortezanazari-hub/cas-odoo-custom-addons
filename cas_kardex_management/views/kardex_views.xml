<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_kardex_day_search" model="ir.ui.view"><field name="name">cas.kardex.day.search</field><field name="model">cas.kardex.day</field><field name="arch" type="xml"><search><field name="employee_id"/><field name="work_date"/><field name="state"/><filter name="warnings" string="نیازمند رسیدگی" domain="[('state','=','warning')]"/><filter name="shortage" string="دارای کسری" domain="[('absence_minutes','&gt;',0)]"/><separator/><filter name="group_employee" string="کارمند" context="{'group_by':'employee_id'}"/><filter name="group_date" string="تاریخ" context="{'group_by':'work_date'}"/><filter name="group_state" string="وضعیت" context="{'group_by':'state'}"/></search></field></record>
