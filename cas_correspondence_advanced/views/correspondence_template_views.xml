<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_correspondence_template_list" model="ir.ui.view">
        <field name="name">cas.correspondence.template.list</field><field name="model">cas.correspondence.template</field>
        <field name="arch" type="xml"><list><field name="sequence" widget="handle"/><field name="name"/><field name="code"/><field name="company_id" groups="base.group_multi_company"/><field name="document_folder_id"/><field name="active"/></list></field>
    </record>
    <record id="view_correspondence_template_form" model="ir.ui.view">
        <field name="name">cas.correspondence.template.form</field><field name="model">cas.correspondence.template</field>
        <field name="arch" type="xml"><form string="قالب رسمی"><sheet><group><group><field name="name"/><field name="code"/><field name="company_id" groups="base.group_multi_company"/></group><group><field name="sequence"/><field name="document_folder_id" domain="[('company_id', '=', company_id)]"/><field name="active"/></group></group><notebook><page string="سربرگ"><field name="header_html"/></page><page string="متن پایه"><field name="subject_pattern"/><field name="body_html"/></page><page string="پابرگ"><field name="footer_html"/></page></notebook></sheet></form></field>
    </record>
    <record id="action_correspondence_templates" model="ir.actions.act_window"><field name="name">قالب‌های رسمی</field><field name="res_model">cas.correspondence.template</field><field name="view_mode">list,form</field></record>
</odoo>
