<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_correspondence_register_search" model="ir.ui.view"><field name="name">cas.correspondence.register.search</field><field name="model">cas.correspondence.register</field><field name="arch" type="xml"><search><field name="number"/><field name="subject"/><field name="counterparty"/><field name="external_number"/><filter name="inbound" string="وارده" domain="[('direction','=','inbound')]"/><filter name="outbound" string="صادره" domain="[('direction','=','outbound')]"/><filter name="open" string="باز" domain="[('state','=','registered')]"/><separator/><filter string="نوع" name="group_direction" context="{'group_by':'direction'}"/><filter string="وضعیت" name="group_state" context="{'group_by':'state'}"/></search></field></record>
    <record id="view_correspondence_register_list" model="ir.ui.view"><field name="name">cas.correspondence.register.list</field><field name="model">cas.correspondence.register</field><field name="arch" type="xml"><list decoration-info="state == 'draft'" decoration-muted="state in ('closed','cancelled')"><field name="number"/><field name="direction" widget="badge"/><field name="subject"/><field name="counterparty"/><field name="external_number"/><field name="registered_at"/><field name="owner_user_id"/><field name="state" widget="badge"/></list></field></record>
    <record id="view_correspondence_register_form" model="ir.ui.view"><field name="name">cas.correspondence.register.form</field><field name="model">cas.correspondence.register</field><field name="arch" type="xml"><form string="ثبت مکاتبه"><header><button name="action_register" type="object" string="ثبت رسمی" class="btn-primary" invisible="state != 'draft'"/><button name="action_close" type="object" string="مختومه" invisible="state != 'registered'"/><field name="state" widget="statusbar" statusbar_visible="draft,registered,closed"/></header><sheet><div class="oe_title"><label for="number"/><h1><field name="number"/></h1><h2><field name="subject" readonly="state != 'draft'"/></h2></div><group><group><field name="direction" readonly="state != 'draft'"/><field name="company_id" readonly="state != 'draft'" groups="base.group_multi_company"/><field name="owner_user_id" readonly="state != 'draft'"/><field name="counterparty" readonly="state != 'draft'"/><field name="channel" readonly="state != 'draft'"/></group><group><field name="external_number" readonly="state != 'draft'"/><field name="external_date" readonly="state != 'draft'"/><field name="confidentiality" readonly="state != 'draft'"/><field name="registered_at"/><field name="document_folder_id" readonly="state != 'draft'" domain="[('company_id','=',company_id)]"/></group></group><notebook><page string="محتوا"><field name="note" readonly="state != 'draft'"/><field name="file_data" filename="file_name" readonly="state != 'draft'" invisible="state != 'draft'"/><field name="file_name" invisible="1"/><field name="attachment_id" readonly="1" invisible="not attachment_id"/></page><page string="سند و امضا" invisible="state == 'draft'"><group><field name="document_id"/><field name="current_sha256"/></group><field name="signature_ids"><list><field name="signer_user_id"/><field name="method"/><field name="state" widget="badge"/><field name="source_digest"/><field name="signed_at"/><button name="action_sign_organizational" type="object" string="امضا" invisible="state != 'pending' or method != 'organizational'"/></list></field></page><page string="تاریخچه" invisible="state == 'draft'"><field name="event_ids"><list create="0" delete="0"><field name="event_at"/><field name="event_type"/><field name="actor_user_id"/><field name="digest"/><field name="note"/></list></field></page></notebook></sheet><chatter/></form></field></record>
    <record id="action_correspondence_registers" model="ir.actions.act_window"><field name="name">دفتر وارده و صادره</field><field name="res_model">cas.correspondence.register</field><field name="view_mode">list,form</field><field name="search_view_id" ref="view_correspondence_register_search"/></record>
