<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cas_correspondence.group_cas_correspondence_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('cas_document_core.group_cas_document_user'))]"/>
    </record>
    <record id="cas_correspondence.group_cas_correspondence_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('cas_document_core.group_cas_document_manager'))]"/>
    </record>

    <record id="rule_template_company" model="ir.rule">
        <field name="name">قالب مکاتبات: شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_correspondence_template"/>
        <field name="groups" eval="[(4, ref('cas_correspondence.group_cas_correspondence_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_register_owner" model="ir.rule">
        <field name="name">ثبت مکاتبات: مسئول رکورد</field>
        <field name="model_id" ref="model_cas_correspondence_register"/>
        <field name="groups" eval="[(4, ref('cas_correspondence.group_cas_correspondence_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids), ('owner_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_register_manager" model="ir.rule">
        <field name="name">ثبت مکاتبات: مدیر شرکت</field>
        <field name="model_id" ref="model_cas_correspondence_register"/>
        <field name="groups" eval="[(4, ref('cas_correspondence.group_cas_correspondence_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_register_event_user" model="ir.rule">
        <field name="name">رویداد ثبت: مسئول رکورد</field>
        <field name="model_id" ref="model_cas_correspondence_register_event"/>
        <field name="groups" eval="[(4, ref('cas_correspondence.group_cas_correspondence_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids), ('register_id.owner_user_id', '=', user.id)]</field>
    </record>
    <record id="rule_register_event_manager" model="ir.rule">
        <field name="name">رویداد ثبت: مدیر شرکت</field>
        <field name="model_id" ref="model_cas_correspondence_register_event"/>
        <field name="groups" eval="[(4, ref('cas_correspondence.group_cas_correspondence_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_signature_user" model="ir.rule">
        <field name="name">امضا: امضاکننده یا ذی‌نفع منبع</field>
        <field name="model_id" ref="model_cas_correspondence_signature"/>
        <field name="groups" eval="[(4, ref('cas_correspondence.group_cas_correspondence_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids), '|', '|', ('signer_user_id', '=', user.id), ('register_id.owner_user_id', '=', user.id), ('letter_id.authorized_user_ids', 'in', user.id)]</field>
    </record>
    <record id="rule_signature_manager" model="ir.rule">
        <field name="name">امضا: مدیر شرکت</field>
        <field name="model_id" ref="model_cas_correspondence_signature"/>
        <field name="groups" eval="[(4, ref('cas_correspondence.group_cas_correspondence_manager'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
