<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_cas_action_hub_sync" model="ir.cron">
        <field name="name">CAS Action Hub: همگام‌سازی اقدامات</field>
        <field name="model_id" ref="model_cas_action_item"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_all()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
    <record id="ir_cron_cas_action_hub_sync_recent" model="ir.cron">
        <field name="name">CAS Action Hub: همگام‌سازی افزایشی</field>
        <field name="model_id" ref="model_cas_action_item"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_recent()</field>
        <field name="interval_number">2</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>
    <record id="ir_cron_cas_action_hub_sla" model="ir.cron">
        <field name="name">CAS Action Hub: یادآوری و تصعید SLA</field>
        <field name="model_id" ref="model_cas_action_item"/>
        <field name="state">code</field>
        <field name="code">model._cron_process_sla()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>
</odoo>
