<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_shift_assignment_list" model="ir.ui.view">
        <field name="name">cas.shift.assignment.list</field><field name="model">cas.shift.assignment</field>
        <field name="arch" type="xml"><list><field name="number"/><field name="name"/><field name="pattern_id"/><field name="policy_id"/><field name="date_from"/><field name="date_to"/><field name="weekly_rest_day"/><field name="day_count"/><field name="state"/><field name="company_id" groups="base.group_multi_company"/></list></field>
    </record>
    <record id="view_cas_shift_assignment_form" model="ir.ui.view">
        <field name="name">cas.shift.assignment.form</field><field name="model">cas.shift.assignment</field>
        <field name="arch" type="xml"><form string="انتساب شیفت">
            <header>
                <button name="action_publish" type="object" string="انتشار و تولید برنامه" class="btn-primary" invisible="state != 'draft'" groups="cas_shift_management.group_cas_shift_planner"/>
                <button name="action_close" type="object" string="بستن" invisible="state != 'published'" groups="cas_shift_management.group_cas_shift_planner"/>
                <button name="action_cancel" type="object" string="لغو" invisible="state not in ['draft', 'published']" groups="cas_shift_management.group_cas_shift_planner"/>
                <field name="state" widget="statusbar" statusbar_visible="draft,published,closed,cancelled"/>
            </header><sheet>
                <div class="oe_button_box" name="button_box"><button name="action_open_days" type="object" class="oe_stat_button" icon="fa-calendar"><field name="day_count" widget="statinfo" string="روزهای تولیدشده"/></button></div>
                <div class="oe_title"><label for="name"/><h1><field name="name" readonly="state != 'draft'"/></h1><field name="number" readonly="1"/></div>
                <group><group><field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/><field name="department_id" readonly="state != 'draft'"/><field name="supervisor_user_id" readonly="state != 'draft'"/><field name="employee_ids" widget="many2many_tags" readonly="state != 'draft'"/></group>
                <group><field name="policy_id" readonly="state != 'draft'"/><field name="pattern_id" readonly="state != 'draft'"/><field name="anchor_date" readonly="state != 'draft'"/><field name="date_from" readonly="state != 'draft'"/><field name="date_to" readonly="state != 'draft'"/></group></group>
                <group string="تقویم قراردادی"><group><field name="weekly_rest_day" readonly="state != 'draft'"/><field name="roster_respects_weekly_rest" readonly="state != 'draft'"/><field name="short_day_enabled" readonly="state != 'draft'"/></group><group><field name="short_day_template_id" readonly="state != 'draft'"/><field name="roster_respects_official_holiday" readonly="state != 'draft'"/></group></group>
                <field name="note" placeholder="توضیحات..."/>
            </sheet><chatter/></form></field>
    </record>
    <record id="action_cas_shift_assignment" model="ir.actions.act_window"><field name="name">انتساب‌های شیفت</field><field name="res_model">cas.shift.assignment</field><field name="view_mode">list,form</field></record>
</odoo>
