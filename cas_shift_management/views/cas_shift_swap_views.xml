<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_shift_swap_list" model="ir.ui.view"><field name="name">cas.shift.swap.list</field><field name="model">cas.shift.swap</field><field name="arch" type="xml"><list><field name="name"/><field name="date_a"/><field name="date_b"/><field name="scope"/><field name="department_id"/><field name="affected_count"/><field name="state"/></list></field></record>
    <record id="view_cas_shift_swap_form" model="ir.ui.view"><field name="name">cas.shift.swap.form</field><field name="model">cas.shift.swap</field><field name="arch" type="xml"><form><header><button name="action_apply" type="object" string="اعمال جابه‌جایی" class="btn-primary" invisible="state != 'draft'" groups="cas_shift_management.group_cas_shift_manager"/><field name="state" widget="statusbar" statusbar_visible="draft,applied"/></header><sheet><div class="oe_title"><label for="name"/><h1><field name="name" readonly="state != 'draft'"/></h1></div><group><group><field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/><field name="date_a" readonly="state != 'draft'"/><field name="date_b" readonly="state != 'draft'"/></group><group><field name="scope" readonly="state != 'draft'"/><field name="department_id" invisible="scope != 'department'" required="scope == 'department'" readonly="state != 'draft'"/><field name="employee_ids" widget="many2many_tags" invisible="scope != 'employees'" required="scope == 'employees'" readonly="state != 'draft'"/></group></group><field name="reason" readonly="state != 'draft'"/><group invisible="state != 'applied'"><field name="affected_count"/><field name="applied_at"/><field name="applied_by_id"/></group></sheet><chatter/></form></field></record>
    <record id="action_cas_shift_swap" model="ir.actions.act_window"><field name="name">جابه‌جایی روزها</field><field name="res_model">cas.shift.swap</field><field name="view_mode">list,form</field></record>
</odoo>
