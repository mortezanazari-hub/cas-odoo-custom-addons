<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_shift_template_list" model="ir.ui.view">
        <field name="name">cas.shift.template.list</field>
        <field name="model">cas.shift.template</field>
        <field name="arch" type="xml">
            <list string="شیفت‌ها">
                <field name="sequence" widget="handle"/>
                <field name="name"/><field name="code"/><field name="shift_kind"/>
                <field name="start_hour" widget="float_time"/><field name="end_hour" widget="float_time"/>
                <field name="presence_minutes"/><field name="default_break_minutes"/><field name="company_id" groups="base.group_multi_company"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="view_cas_shift_template_form" model="ir.ui.view">
        <field name="name">cas.shift.template.form</field>
        <field name="model">cas.shift.template</field>
        <field name="arch" type="xml">
            <form string="شیفت">
                <sheet>
                    <div class="oe_title"><label for="name"/><h1><field name="name"/></h1></div>
                    <group>
                        <group><field name="code"/><field name="shift_kind"/><field name="company_id" groups="base.group_multi_company"/><field name="active"/></group>
                        <group><field name="timezone"/><field name="start_hour" widget="float_time"/><field name="end_hour" widget="float_time"/><field name="presence_minutes" readonly="1"/></group>
                    </group>
                    <group string="قواعد"><field name="default_break_minutes"/><field name="work_date_rule"/><field name="manual_work_date_allowed"/></group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_cas_shift_template" model="ir.actions.act_window">
        <field name="name">شیفت‌ها</field><field name="res_model">cas.shift.template</field><field name="view_mode">list,form</field>
    </record>
</odoo>
