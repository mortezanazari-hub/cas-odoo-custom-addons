<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_shift_day_search" model="ir.ui.view"><field name="name">cas.shift.day.search</field><field name="model">cas.shift.day</field><field name="arch" type="xml"><search><field name="employee_id"/><field name="schedule_date"/><field name="template_id"/><filter name="work" string="روزهای کاری" domain="[('day_kind','=','work')]"/><filter name="off" string="روزهای تعطیل" domain="[('day_kind','!=','work')]"/><separator/><filter name="group_employee" string="کارمند" context="{'group_by':'employee_id'}"/><filter name="group_date" string="تاریخ" context="{'group_by':'schedule_date'}"/><filter name="group_day_kind" string="نوع روز" context="{'group_by':'day_kind'}"/></search></field></record>
    <record id="view_cas_shift_day_list" model="ir.ui.view"><field name="name">cas.shift.day.list</field><field name="model">cas.shift.day</field><field name="arch" type="xml"><list create="0" edit="0" delete="0"><field name="schedule_date"/><field name="employee_id"/><field name="day_kind"/><field name="template_id"/><field name="planned_start"/><field name="planned_end"/><field name="base_work_minutes"/><field name="break_minutes"/><field name="required_presence_minutes"/><field name="mandatory_overtime_minutes"/><field name="attendance_mode"/><field name="rule_origin_date"/><field name="swapped_by_id" optional="show"/><field name="state"/></list></field></record>
    <record id="view_cas_shift_day_form" model="ir.ui.view"><field name="name">cas.shift.day.form</field><field name="model">cas.shift.day</field><field name="arch" type="xml"><form create="0" edit="0" delete="0"><sheet><group><group><field name="employee_id"/><field name="schedule_date"/><field name="rule_origin_date"/><field name="day_kind"/><field name="template_id"/></group><group><field name="planned_start"/><field name="planned_end"/><field name="base_work_minutes"/><field name="break_minutes"/><field name="required_presence_minutes"/><field name="mandatory_overtime_minutes"/></group></group><group string="منشأ و سیاست"><field name="assignment_id"/><field name="policy_id"/><field name="attendance_mode"/><field name="source_tolerance_minutes"/><field name="calendar_date_is_official_holiday"/><field name="rule_is_official_holiday"/><field name="rule_is_weekly_rest"/><field name="rule_is_short_day"/><field name="swapped_by_id"/></group></sheet><chatter/></form></field></record>
    <record id="action_cas_shift_day" model="ir.actions.act_window"><field name="name">برنامه روزانه</field><field name="res_model">cas.shift.day</field><field name="view_mode">list,form</field></record>
    <record id="action_cas_my_shift_day" model="ir.actions.act_window"><field name="name">برنامه من</field><field name="res_model">cas.shift.day</field><field name="view_mode">list,form</field><field name="domain">[('employee_id.user_id', '=', uid)]</field></record>
    <record id="view_cas_official_holiday_list" model="ir.ui.view"><field name="name">cas.official.holiday.list</field><field name="model">cas.official.holiday</field><field name="arch" type="xml"><list><field name="date"/><field name="name"/><field name="company_id" groups="base.group_multi_company"/><field name="active"/></list></field></record>
    <record id="view_cas_official_holiday_form" model="ir.ui.view"><field name="name">cas.official.holiday.form</field><field name="model">cas.official.holiday</field><field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="date"/><field name="company_id" groups="base.group_multi_company"/><field name="active"/></group><field name="note"/></sheet><chatter/></form></field></record>
    <record id="action_cas_official_holiday" model="ir.actions.act_window"><field name="name">تعطیلات رسمی</field><field name="res_model">cas.official.holiday</field><field name="view_mode">list,form</field></record>
</odoo>
