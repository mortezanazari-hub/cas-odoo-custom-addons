<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_attendance_policy_list" model="ir.ui.view">
        <field name="name">cas.attendance.policy.list</field><field name="model">cas.attendance.policy</field>
        <field name="arch" type="xml"><list><field name="name"/><field name="code"/><field name="attendance_mode"/><field name="source_tolerance_minutes"/><field name="normal_work_minutes"/><field name="short_work_minutes"/><field name="company_id" groups="base.group_multi_company"/><field name="active" optional="hide"/></list></field>
    </record>
    <record id="view_cas_attendance_policy_form" model="ir.ui.view">
        <field name="name">cas.attendance.policy.form</field><field name="model">cas.attendance.policy</field>
        <field name="arch" type="xml">
            <form><sheet><div class="oe_title"><label for="name"/><h1><field name="name"/></h1></div>
                <group><group><field name="code"/><field name="company_id" groups="base.group_multi_company"/><field name="attendance_mode"/><field name="active"/></group>
                <group><field name="source_tolerance_minutes"/><field name="auto_close_mixed_sources"/><field name="allow_guard_work_date_choice"/></group></group>
                <group string="موظفی و استراحت"><group><field name="normal_work_minutes"/><field name="normal_break_minutes"/></group><group><field name="short_work_minutes"/><field name="short_day_extended_break_minutes"/></group></group>
            </sheet><chatter/></form>
        </field>
    </record>
    <record id="action_cas_attendance_policy" model="ir.actions.act_window"><field name="name">سیاست‌های حضور</field><field name="res_model">cas.attendance.policy</field><field name="view_mode">list,form</field></record>
</odoo>
