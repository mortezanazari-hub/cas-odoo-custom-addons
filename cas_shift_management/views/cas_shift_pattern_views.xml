<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cas_shift_pattern_list" model="ir.ui.view">
        <field name="name">cas.shift.pattern.list</field><field name="model">cas.shift.pattern</field>
        <field name="arch" type="xml"><list><field name="name"/><field name="code"/><field name="cycle_length"/><field name="company_id" groups="base.group_multi_company"/><field name="active" optional="hide"/></list></field>
    </record>
    <record id="view_cas_shift_pattern_form" model="ir.ui.view">
        <field name="name">cas.shift.pattern.form</field><field name="model">cas.shift.pattern</field>
        <field name="arch" type="xml"><form><sheet>
            <div class="oe_title"><label for="name"/><h1><field name="name"/></h1></div>
            <group><group><field name="code"/><field name="company_id" groups="base.group_multi_company"/></group><group><field name="cycle_length"/><field name="active"/></group></group>
            <field name="line_ids"><list editable="bottom"><field name="cycle_day"/><field name="day_kind"/><field name="template_id" domain="[('company_id', '=', parent.company_id)]" required="day_kind == 'work'"/></list></field>
        </sheet><chatter/></form></field>
    </record>
    <record id="action_cas_shift_pattern" model="ir.actions.act_window"><field name="name">الگوهای گردشی</field><field name="res_model">cas.shift.pattern</field><field name="view_mode">list,form</field></record>
</odoo>
