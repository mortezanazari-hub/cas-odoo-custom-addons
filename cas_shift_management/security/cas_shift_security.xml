<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_cas_shift_user" model="res.groups">
        <field name="name">کاربر شیفت</field>
    </record>
    <record id="group_cas_shift_planner" model="res.groups">
        <field name="name">برنامه‌ریز شیفت</field>
        <field name="implied_ids" eval="[(4, ref('group_cas_shift_user'))]"/>
    </record>
    <record id="group_cas_shift_manager" model="res.groups">
        <field name="name">مدیر شیفت و تقویم</field>
        <field name="implied_ids" eval="[(4, ref('group_cas_shift_planner'))]"/>
    </record>
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('cas_shift_management.group_cas_shift_manager'))]"/>
    </record>

    <record id="rule_cas_attendance_policy_company" model="ir.rule">
        <field name="name">سیاست‌های حضور شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_attendance_policy"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_cas_shift_user'))]"/>
    </record>
    <record id="rule_cas_shift_template_company" model="ir.rule">
        <field name="name">شیفت‌های شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_shift_template"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_cas_shift_user'))]"/>
    </record>
    <record id="rule_cas_shift_pattern_company" model="ir.rule">
        <field name="name">الگوهای شیفت شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_shift_pattern"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_cas_shift_user'))]"/>
    </record>
    <record id="rule_cas_shift_pattern_line_company" model="ir.rule">
        <field name="name">روزهای الگوی شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_shift_pattern_line"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_cas_shift_user'))]"/>
    </record>
    <record id="rule_cas_official_holiday_company" model="ir.rule">
        <field name="name">تعطیلات رسمی شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_official_holiday"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_cas_shift_user'))]"/>
    </record>
    <record id="rule_cas_shift_assignment_own" model="ir.rule">
        <field name="name">انتساب‌های خود کاربر</field>
        <field name="model_id" ref="model_cas_shift_assignment"/>
        <field name="domain_force">[('company_id', 'in', company_ids), ('employee_ids.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_cas_shift_user'))]"/>
    </record>
    <record id="rule_cas_shift_assignment_planner" model="ir.rule">
        <field name="name">انتساب‌های شرکت برای برنامه‌ریز</field>
        <field name="model_id" ref="model_cas_shift_assignment"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_cas_shift_planner'))]"/>
    </record>
    <record id="rule_cas_shift_day_own" model="ir.rule">
        <field name="name">برنامه‌های روزانه خود کاربر</field>
        <field name="model_id" ref="model_cas_shift_day"/>
        <field name="domain_force">[('company_id', 'in', company_ids), ('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_cas_shift_user'))]"/>
    </record>
    <record id="rule_cas_shift_day_planner" model="ir.rule">
        <field name="name">برنامه‌های روزانه شرکت برای برنامه‌ریز</field>
        <field name="model_id" ref="model_cas_shift_day"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_cas_shift_planner'))]"/>
    </record>
    <record id="rule_cas_shift_swap_company" model="ir.rule">
        <field name="name">جابه‌جایی‌های شرکت‌های مجاز</field>
        <field name="model_id" ref="model_cas_shift_swap"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_cas_shift_planner'))]"/>
    </record>
</odoo>
